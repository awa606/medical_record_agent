# Department pilot environment template.
# Copy to config/pilot.department.env and fill secrets locally.
# Do not commit the copied file.

MRA_HOST_PORT=2626

# Pilot safety mode. edge/live rejects MockLLM fallback and weak bootstrap passwords.
RECORD_PROVIDER_MODE=edge

# Runtime paths inside the Docker container.
MEDICAL_RECORD_AGENT_DB=/app/runtime/medical_record_agent.sqlite3
MEDICAL_RECORD_AGENT_UPLOAD_DIR=/app/runtime/uploads
MEDICAL_RECORD_AGENT_OUTPUT_DIR=/app/runtime/outputs
MEDICAL_RECORD_AGENT_SPEAKER_PROFILE_DIR=/app/runtime/speaker_profiles
MEDICAL_RECORD_AGENT_MIN_FREE_BYTES=1073741824
MEDICAL_RECORD_AGENT_MAX_UPLOAD_BYTES=209715200
MEDICAL_RECORD_AGENT_MAX_RECORDING_CHUNK_BYTES=16777216
MEDICAL_RECORD_AGENT_MAX_RECORDING_SECONDS=1800

# Login bootstrap. Set a strong local value before first edge/live startup.
MEDICAL_RECORD_AGENT_AUTH_BOOTSTRAP=1
MEDICAL_RECORD_AGENT_BOOTSTRAP_ADMIN_USERNAME=pilot_admin
MEDICAL_RECORD_AGENT_BOOTSTRAP_ADMIN_PASSWORD=
MEDICAL_RECORD_AGENT_BOOTSTRAP_ADMIN_DISPLAY_NAME=Department Pilot Admin
MEDICAL_RECORD_AGENT_SESSION_HOURS=8
MEDICAL_RECORD_AGENT_COOKIE_SECURE=0

# LLM provider. The example defaults to local Ollama so no API key is required.
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=
LLM_TIMEOUT_SECONDS=30

# Optional OpenAI-compatible provider. Leave blank unless selected by LLM_PROVIDER=online.
ONLINE_LLM_API_BASE=
ONLINE_LLM_API_KEY=
ONLINE_LLM_MODEL=

# Optional online ASR provider. Leave blank unless using engine=online.
ONLINE_ASR_API_URL=
ONLINE_ASR_API_KEY=

# ASR/runtime defaults for the local pilot container.
ASR_SESSION_CHUNK_ENABLED=1
ASR_SESSION_DYNAMIC_CHUNKING=1
ASR_SESSION_REALTIME_UPLOAD_ENABLED=1
MODELSCOPE_CACHE=/app/model_cache/modelscope
HF_HOME=/app/model_cache/hf
TORCH_HOME=/app/model_cache/torch
FUNASR_STREAMING_MODEL_ID=ParaformerStreaming
FUNASR_STREAMING_SEGMENT_SECONDS=6
FUNASR_DEVICE=cpu
FUNASR_DISABLE_UPDATE=1
ASR_PREWARM_ENABLED=1
MEDICAL_RECORD_AGENT_REQUIRE_FUNASR=1
MEDICAL_RECORD_AGENT_FUNASR_CACHE_MIN_FILES=5
SENSEVOICE_DEVICE=cpu
SENSEVOICE_LANGUAGE=zh
SENSEVOICE_HUB=hf
CAMPP_SPEAKER_DEVICE=cpu
SPEAKER_ROLE_PROVIDER=rules
SPEAKER_ROLE_OLLAMA_BASE_URL=http://host.docker.internal:11434
SPEAKER_ROLE_OLLAMA_MODEL=qwen3:4b-instruct
